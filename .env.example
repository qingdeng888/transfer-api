# Transfer-API 环境变量配置示例
# 使用方法：cp .env.example .env，然后填写你的真实值

# 上游 API 配置
UPSTREAM_BASE_URL=https://unlimited.surf

# 你的 unlimited.surf API Key（必需）
# 从 https://unlimited.surf 获取你的 API Key 填入下方
UNLIMITED_SURF_API_KEY=your-api-key-here

# 默认模型名称
DEFAULT_MODEL=gateway-gpt-5-5
DEFAULT_CLAUDE_MODEL=claude-opus-4-7-20260101

# 自定义访问密钥（可选，留空即不启用）
# 启用后，客户端访问需要在请求头中携带此密钥
WORKER_API_KEY=

# 服务端口（可选，默认 8787）
# Docker 内部固定 8787，如需修改外部映射，在 docker-compose.yml 中调整
PORT=8787
